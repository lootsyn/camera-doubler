FROM python:3.12.10-slim-bookworm@sha256:fd95fa221297a88e1cf49c55ec1828edd7c5a428187e67b5d1805692d11588db

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 10001 dataset \
    && useradd --uid 10001 --gid dataset --no-create-home --shell /usr/sbin/nologin dataset
WORKDIR /app
# requirements.txt MUST pin the exact LeRobot version and every dataset/video
# dependency. Bare, floating `lerobot` installs are forbidden. Startup must compare
# the installed version with LEROBOT_VERSION and fail closed on mismatch.
COPY python/dataset_builder/requirements.lock ./requirements.lock
RUN pip install --no-cache-dir -r requirements.lock \
    && pip check
COPY python/dataset_builder/ ./
ENV HOME=/tmp \
    HF_HOME=/tmp/huggingface \
    XDG_CACHE_HOME=/tmp/.cache
USER 10001:10001
ENTRYPOINT ["python", "-m", "app"]

# LeRobot Dataset Builder
DATA_ROOT=/data
API_BIND=0.0.0.0:8090

# Exact installed-version contract. The container must refuse startup on mismatch.
# Reference pin verified when this specification was revised; update only through a
# compatibility-tested change that regenerates the lockfile and review evidence.
LEROBOT_VERSION=0.6.0
LEROBOT_DATASET_FORMAT=v3

# Staging may use anchor-native timing, but final export must not silently claim a
# regular FPS when cadence is outside tolerance.
LEROBOT_CADENCE_POLICY=reject_irregular
LEROBOT_EXPORT_COMMIT_MODE=atomic
LEROBOT_VALIDATE_AFTER_EXPORT=true
LEROBOT_PUSH_TO_HUB=false
LEROBOT_REPOSITORY_ID=
EXPORT_TEMP_ROOT=/data/.exports
